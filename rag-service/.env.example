APP_NAME=rag-service
ENVIRONMENT=local
LOG_LEVEL=INFO

LAW_SERVICE_BASE_URL=http://localhost:8080
LAW_SERVICE_ADMIN_TOKEN=

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=legal_document_chunks
QDRANT_DELETE_EXISTING_CHUNKS=true
QDRANT_TIMEOUT_SECONDS=120
QDRANT_UPSERT_BATCH_SIZE=64

REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

RABBITMQ_URL=amqp://law:law@localhost:5672/
RABBITMQ_EMBEDDING_QUEUE=law.embedding.update

ANSWER_LANGUAGE=Vietnamese

EMBEDDING_MODEL_NAME=mainguyen9/vietlegal-harrier-0.6b
EMBEDDING_DIMENSION=1024
EMBEDDING_QUERY_INSTRUCTION=Instruct: Given a Vietnamese legal question, retrieve relevant legal passages that answer the question\nQuery: 
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_LOCAL_FILES_ONLY=false
RERANKER_MODEL_NAME=Qwen/Qwen3-Reranker-0.6B
RERANKER_QUERY_INSTRUCTION=Given a Vietnamese legal question, retrieve relevant legal passages that answer the question\nQuery: 
ENABLE_RERANKER=true

LLM_PROVIDER=stub
LLM_API_TYPE=chat_completions
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=luanngo/Qwen3-4B-VietNamese-Legal-Chat
LLM_REASONING_EFFORT=
LLM_MAX_OUTPUT_TOKENS=4096

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
